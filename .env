# ======================================================================
# TokenMind local / hackathon defaults
# Safe to commit for local Docker startup. Replace before real deployment.
# ======================================================================

PROJECT_NAME=TokenMind
VERSION=1.0.0
DEBUG=False
TARGET=production

NODE_ENV=production
NEXT_PUBLIC_API_URL=http://localhost:8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tokenmind
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tokenmind

SECRET_KEY=tokenmind-local-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
EMAIL_VERIFY_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
OTP_TOKEN_EXPIRE_MINUTES=10
OTP_HMAC_SECRET=tokenmind-local-otp-secret
REQUIRE_EMAIL_VERIFICATION=False

ENABLE_CORS=True
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000"]

ENABLE_REDIS=True
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=redis
REDIS_URL=redis://:redis@redis:6379/0
PATENT_CACHE_TTL_HOURS=48

ENABLE_IP_INTEL=True
USPTO_API_KEY=
EPO_OPS_CONSUMER_KEY=
EPO_OPS_CONSUMER_SECRET=
WIPO_API_KEY=
EXTERNAL_API_RATE_LIMIT=5.0
EXTERNAL_API_TIMEOUT=30.0
ENABLE_EXTERNAL_API_AUDIT=True

SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_VERIFICATION=True
MARKETPLACE_NETWORK=solana-devnet
MARKETPLACE_TREASURY_WALLET=9xQeWvG816bUx9EPfEZj3J2m55Cmw7oQwWJ4y9ZVJvUh

ENABLE_SMS_OTP=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tokenmind.local

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ip-documents
MINIO_USE_SSL=False

ADMIN_EMAIL=admin@tokenmind.local
ADMIN_PASSWORD=Admin123!

ENABLE_ADMIN_PANEL=True
ENABLE_USER_REGISTRATION=True
ENABLE_USER_DELETE=True
ENABLE_FILE_UPLOAD=True
ENABLE_PATENT_SEARCH=True
ENABLE_PATENT_ENRICHMENT=True
ENABLE_KYC_VERIFICATION=True
ENABLE_WALLET_MANAGEMENT=True
ENABLE_DEBUG_ENDPOINTS=False
ENABLE_SEED_DATA=False
ENABLE_MOCK_EXTERNAL_APIS=False

APP_HOST=0.0.0.0
APP_PORT=8000
WORKERS_COUNT=4
WORKER_TIMEOUT=120
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_LOGGING=True
ENABLE_REQUEST_LOGGING=False
LOG_REQUEST_BODY=False
LOG_RESPONSE_BODY=False
LOG_SQL_QUERIES=False