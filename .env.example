# ======================================================================
# TokenMind Environment Variables
# ======================================================================

# Build/Run target (production or development)
TARGET=production

# Frontend
NODE_ENV=production
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
DEBUG=False

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tokenmind

# Redis
REDIS_PASSWORD=redis

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ip-documents
