# ======================================================================
# TokenMind Environment Variables
# ======================================================================
# Copy to .env and fill real values.
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY should match
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD.
# ======================================================================

# ======================================================================
# Frontend (optional profile)
# ======================================================================
NODE_ENV=production
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SOLANA_RPC_URL=http://host.docker.internal:8899
NEXT_PUBLIC_SOLANA_PROGRAM_ID=4XeEJCxc1TLRaFzyfjYjELPdExY1imRAqiZqjuRqz6Kt
NEXT_PUBLIC_SOLANA_NETWORK=localnet
NEXT_PUBLIC_SOLANA_PLATFORM_TREASURY=11111111111111111111111111111111

# ======================================================================
# Backend
# ======================================================================
PROJECT_NAME=IPChain
VERSION=0.1.0
DEBUG=False
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tokenmind
REDIS_URL=redis://:redis@redis:6379/0

# ======================================================================
# PostgreSQL
# ======================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tokenmind

# ======================================================================
# Redis
# ======================================================================
ENABLE_REDIS=True
REDIS_PASSWORD=redis

# ======================================================================
# MinIO / S3
# ======================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=ip-documents
MINIO_USE_SSL=False

# ======================================================================
# CORS
# ======================================================================
ENABLE_CORS=True
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ======================================================================
# JWT & Security
# ======================================================================
SECRET_KEY=change-me-in-production-use-32-random-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ======================================================================
# Email / OTP
# ======================================================================
ENABLE_SMS_OTP=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@localhost
OTP_HMAC_SECRET=replace-with-32-random-bytes-hex

# ======================================================================
# IP Intelligence
# ======================================================================
ENABLE_IP_INTEL=True
USPTO_API_KEY=
EPO_OPS_CONSUMER_KEY=
EPO_OPS_CONSUMER_SECRET=
WIPO_API_KEY=
EXTERNAL_API_RATE_LIMIT=5.0
EXTERNAL_API_TIMEOUT=30.0
ENABLE_EXTERNAL_API_AUDIT=True
PATENT_CACHE_TTL_HOURS=48

# ======================================================================
# Solana / Blockchain
# Run `solana-test-validator --reset` on the host and keep these values
# in sync with the deployed Anchor program in ./certs.
# ======================================================================
ENABLE_BLOCKCHAIN=True
SOLANA_NETWORK=localnet
SOLANA_RPC_URL=http://host.docker.internal:8899
SOLANA_COMMITMENT=confirmed
SOLANA_PROGRAM_ID=4XeEJCxc1TLRaFzyfjYjELPdExY1imRAqiZqjuRqz6Kt
SOLANA_PLATFORM_TREASURY=11111111111111111111111111111111
SOLANA_EXPLORER_BASE_URL=https://explorer.solana.com
