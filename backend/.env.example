# ======================================================================
# Application Settings
# ======================================================================
PROJECT_NAME=IP Tokenization Platform
VERSION=1.0.0
DEBUG=False

# ======================================================================
# Database Settings (PostgreSQL)
# ======================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ip_tokenization

# ======================================================================
# JWT & Security
# ======================================================================
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ======================================================================
# CORS Settings
# ======================================================================
ENABLE_CORS=True
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ======================================================================
# Redis Settings
# ======================================================================
ENABLE_REDIS=True
REDIS_URL=redis://:redis@redis:6379/0
REDIS_PASSWORD=redis

# Patent cache TTL in hours (default: 48)
PATENT_CACHE_TTL_HOURS=48

# ======================================================================
# IP Intelligence Module (Patent APIs)
# ======================================================================
ENABLE_IP_INTEL=True

# USPTO API Key - register at https://developer.uspto.gov/
USPTO_API_KEY=

# EPO OPS OAuth2 - register at https://worldwide.espacenet.com/ops
EPO_OPS_CONSUMER_KEY=
EPO_OPS_CONSUMER_SECRET=

# WIPO PATENTSCOPE API Key (optional)
WIPO_API_KEY=

# External API rate limit (calls per second)
EXTERNAL_API_RATE_LIMIT=5.0

# External API timeout (seconds)
EXTERNAL_API_TIMEOUT=30.0

# Enable audit logging for external API calls
ENABLE_EXTERNAL_API_AUDIT=True

# ======================================================================
# MinIO / S3 Object Storage
# ======================================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ip-documents
MINIO_USE_SSL=False

# ======================================================================
# Email / Notifications (optional)
# ======================================================================
# Email OTP — Gmail SMTP (free). Enable 2FA in Google Account and create an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ds
SMTP_PASSWORD=sd
SMTP_FROM_EMAIL=mail

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OTP_HMAC_SECRET=secre